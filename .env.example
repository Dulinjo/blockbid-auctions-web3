# =====================================================================
# BlockBid — example environment configuration
#
# Copy this file to `.env` and fill in real values for local development.
# `.env` is git-ignored and MUST NEVER be committed.
#
# All values exposed to the browser must be prefixed with VITE_ so Vite
# can inline them at build time. Only commit truly public values to your
# real .env.
# =====================================================================

# --- Lovable Cloud / Supabase backend (used by the AI assistant + auction
#     metadata storage). The publishable / anon key is safe to expose in
#     client code; the URL and project id are likewise public.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-supabase-project-ref"

# --- Smart contract deployment (Sepolia testnet)
# The address of the BlockBidAuction contract you want the UI to talk to.
# Replace with your own deployment if you redeploy from Remix.
VITE_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# --- WalletConnect / Reown
# Get a free projectId at https://cloud.reown.com.
# This is a publishable id (safe in the browser). MetaMask, Coinbase and
# other injected wallets work even when this is left empty — only the
# WalletConnect mobile QR flow requires a valid id.
VITE_WALLETCONNECT_PROJECT_ID=""
