# =========================================================
# LexVibe - environment configuration
# Copy to `.env` and set secure values.
# =========================================================

# Required by FastAPI/LangChain backend.
OPENAI_API_KEY="sk-..."

# Used by Next auth route for protecting /admin.
ADMIN_PASSWORD="strong_admin_password_here"

# Optional hybrid retrieval controls (BM25 + vector).
RAG_VECTOR_WEIGHT="0.72"
RAG_RETRIEVAL_K="12"
RAG_ANSWER_TOP_K="4"

# Optional external transformer reranker service.
TRANSFORMER_RERANKER_URL=""
TRANSFORMER_RERANKER_API_KEY=""
TRANSFORMER_RERANKER_TIMEOUT="6"

# Optional service for regulations lookup (Službeni glasnik mirror/proxy).
SLUZBENI_GLASNIK_API_URL=""
SLUZBENI_GLASNIK_API_KEY=""

